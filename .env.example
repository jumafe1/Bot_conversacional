# =============================================================================
# Rappi Conversational Bot — Environment Variables Template
# =============================================================================

# --- LLM Providers -----------------------------------------------------------

# OpenAI API key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic API key (optional, used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# --- LLM Configuration -------------------------------------------------------

# Provider to use: "openai" | "anthropic"
LLM_PROVIDER=openai

# Model identifier. For OpenAI: gpt-5.4-mini, gpt-4o, etc.
# Note: GPT-5.x / o-series models require ``max_completion_tokens`` (already
# handled by llm_service) and most of them ignore or reject a non-default
# ``LLM_TEMPERATURE``. Leave temperature empty or at 1.0 for that family.
LLM_MODEL=gpt-5.4-mini

# Maximum tokens in LLM response
LLM_MAX_TOKENS=2048

# Temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# --- Data Paths --------------------------------------------------------------

# Directory where clean parquet files live (relative to project root)
DATA_DIR=data/processed

# --- Application -------------------------------------------------------------

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS allowed origins (JSON list as string)
CORS_ORIGINS=["http://localhost:3000"]
